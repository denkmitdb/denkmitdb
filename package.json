{
    "name": "@denkmitdb/denkmitdb",
    "version": "1.0.0",
    "description": "Distributed Merkle Tree Database on IPFS",
    "main": "./dist/functions/index.js",
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "types": "./dist/functions/index.d.ts",
    "files": [
        "src",
        "dist",
        "!dist/test",
        "!**/*.tsbuildinfo"
    ],
    "exports": {
        ".": {
            "types": "./dist/functions/index.d.ts",
            "import": "./dist/functions/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "rm -rf dist && tsc && tsc --declaration --emitDeclarationOnly",
        "docs": "typedoc",
        "lint": "eslint src test examples vitest.config.ts",
        "typecheck": "tsc -p tsconfig.test.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:package": "node scripts/package-smoke.mjs"
    },
    "keywords": [
        "denkmitdb",
        "denkmitdb-typescript"
    ],
    "author": "Askar Zhakenov <askar@zhakenov.pro>",
    "license": "MIT",
    "homepage": "https://github.com/denkmitdb/denkmitdb",
    "repository": {
        "type": "git",
        "url": "https://github.com/denkmitdb/denkmitdb.git"
    },
    "bugs": {
        "url": "https://github.com/denkmitdb/denkmitdb/issues"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.1.0",
        "@eslint/js": "^9.4.0",
        "@microsoft/tsdoc": "^0.15.0",
        "@ptkdev/all-shields-cli": "^2.0.2",
        "@types/eslint__js": "^8.42.3",
        "@types/node": "^22.20.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^9.4.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-formatter-unix": "^8.40.0",
        "eslint-plugin-tsdoc": "^0.3.0",
        "globals": "^15.4.0",
        "prettier": "^3.9.5",
        "ts-node": "^10.9.2",
        "tsx": "^4.12.0",
        "typedoc": "^0.28.20",
        "typedoc-plugin-markdown": "^4.12.0",
        "typedoc-plugin-mdn-links": "^5.1.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.64.0",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@chainsafe/libp2p-gossipsub": "^14.1.2",
        "@chainsafe/libp2p-noise": "^16.1.5",
        "@chainsafe/libp2p-yamux": "^7.0.4",
        "@helia/dag-cbor": "^4.1.0",
        "@ipld/dag-cbor": "^9.2.0",
        "@libp2p/identify": "^3.0.39",
        "@libp2p/interface": "^2.11.0",
        "@libp2p/logger": "^5.2.0",
        "@libp2p/tcp": "^10.1.19",
        "@types/json-logic-js": "^2.0.7",
        "delay": "^7.0.0",
        "helia": "^5.5.1",
        "interface-datastore": "^9.0.3",
        "it-drain": "^3.0.7",
        "jose": "^6.2.3",
        "js-sdsl": "^4.4.2",
        "json-logic-js": "^2.0.2",
        "keyv": "^5.6.0",
        "libp2p": "^2.10.0",
        "multiformats": "^13.1.1",
        "p-queue": "^9.3.1",
        "timeout-abort-controller": "^3.0.0",
        "uint8arrays": "^6.1.1",
        "utility-types": "^3.11.0"
    },
    "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a",
    "pnpm": {
        "overrides": {
            "interface-datastore": "9.0.3"
        }
    }
}
