        "@denkmitdb/denkmitdb": "file:..",
        "@libp2p/floodsub": "^11",
        "@libp2p/identify": "^4.1.9",
        "@libp2p/mdns": "^12.0.26",
        "@libp2p/tcp": "^11.0.23",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@multiformats/multiaddr": "^13.0.1",
        "blockstore-fs": "^3.0.3",
        "datastore-fs": "^11.0.4",
        "helia": "^6.1.4",
        "libp2p": "^3.3.5",
        "multiformats": "^13.4.2",
